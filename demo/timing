#!/bin/bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT="${1:-.}"
OUT_DIR="${2:-.}"

Rscript --vanilla "${SCRIPT_DIR}/parse_demo_results.R" "${ROOT}" "${OUT_DIR}"

if [ -f "${OUT_DIR}/timing.tex" ] && command -v latexmk >/dev/null 2>&1; then
  (
    cd "${OUT_DIR}"
    latexmk -pdf timing
  )
fi
